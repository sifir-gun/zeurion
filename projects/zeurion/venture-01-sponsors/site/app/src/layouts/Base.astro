---
import '../styles/global.css';
import verticalsData from '../data/verticals.json';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const verticals = verticalsData.verticals;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <script>
      document.documentElement.classList.add('js');
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }),
        { rootMargin: '0px 0px -8% 0px' }
      );
      window.addEventListener('DOMContentLoaded', () =>
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el))
      );
    </script>
    <header class="site-head">
      <div class="container head-inner">
        <a class="wordmark" href="/">zeurion<span class="accent-dot">.</span></a>
        <nav aria-label="Main">
          <a href="/sample">Sample</a>
          <a href="/who-sponsors/">Verticals</a>
          <a href="/calculator">Calculator</a>
          <a href="/#buy" class="head-cta">€349</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer>
      <div class="container footer-resources">
        <span class="mono footer-label">Free resources</span>
        <nav aria-label="Resources">
          <a href="/calculator">Sponsorship rate calculator</a>
          {verticals.map((v) => (
            <a href={`/who-sponsors/${v.slug}`}>Who sponsors {v.name} newsletters</a>
          ))}
        </nav>
      </div>
      <div class="container footer-inner">
        <span class="mono footer-brand">zeurion.ai</span>
        <nav aria-label="Legal">
          <a href="/legal">Legal notice</a>
          <a href="/terms">Terms</a>
          <a href="/privacy">Privacy</a>
          <a href="mailto:contact@zeurion.ai">contact@zeurion.ai</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-head {
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .head-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.85rem;
    padding-bottom: 0.85rem;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
  }
  .accent-dot { color: var(--accent); }
  .site-head nav { display: flex; align-items: center; gap: 1.5rem; }
  .site-head nav a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .site-head nav a:hover { color: var(--accent); }
  .head-cta {
    font-family: var(--font-mono);
    border: 1.5px solid var(--accent);
    color: var(--accent) !important;
    border-radius: 6px;
    padding: 0.25rem 0.7rem;
    font-size: 0.85rem !important;
  }
  .head-cta:hover { background: var(--accent); color: var(--accent-ink) !important; }

  footer {
    border-top: 1px solid var(--line);
    margin-top: 5rem;
    padding: 2rem 0;
  }
  .footer-resources {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    font-size: 0.875rem;
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--line);
  }
  .footer-label { color: var(--ink-soft); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .footer-resources nav { display: flex; flex-wrap: wrap; gap: 1.25rem; }
  .footer-resources nav a { color: var(--ink-soft); text-decoration: none; }
  .footer-resources nav a:hover { color: var(--accent); }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
    font-size: 0.875rem;
  }
  .footer-brand { color: var(--ink-soft); }
  nav { display: flex; flex-wrap: wrap; gap: 1.25rem; }
  nav a { color: var(--ink-soft); text-decoration: none; }
  nav a:hover { color: var(--accent); }
</style>
