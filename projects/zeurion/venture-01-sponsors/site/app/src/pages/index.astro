---
import Base from '../layouts/Base.astro';
import verticalsData from '../data/verticals.json';

const verticals = verticalsData.verticals;

// Lien de paiement Stripe : à renseigner par Guney depuis le dashboard Stripe.
// Tant qu'il est vide, le bouton d'achat est désactivé (vente bloquée : pages
// légales à finaliser, voir site/donnees-legales.md).
const STRIPE_PAYMENT_LINK = '';

const inboxRows = [
  { tier: 1, brand: 'Tines', subject: 'Same campaign in 4 newsletters, 5 weeks', tag: 'PRIMARY ×5', date: 'Jul 06' },
  { tier: 1, brand: 'Sublime Security', subject: 'Bought a full Risky Business week', tag: 'TAKEOVER', date: 'Jul 10' },
  { tier: 1, brand: 'Corelight', subject: 'Weekly pack with sponsored demo', tag: 'PRIMARY ×3', date: 'Jul 01' },
  { tier: 1, brand: 'Nebulock', subject: 'Paid a wholly sponsored episode', tag: 'DEDICATED', date: 'Jul 08' },
  { tier: 2, brand: 'ThreatLocker', subject: 'On every episode since April', tag: 'AUDIO ×10', date: 'Jul 21' },
  { tier: 2, brand: 'runZero', subject: 'Three titles inside three weeks', tag: 'PRIMARY ×3', date: 'Jun 26' },
];

const faq = [
  {
    q: 'My list is under 5,000 subscribers. Is this for me?',
    a: 'Honest answer: direct sponsorship sales work best for niched B2B or prosumer newsletters from roughly 2,000 engaged subscribers, and get materially easier above 5,000. If your list is general-interest and small, an ad network is probably a better first step, and we would rather tell you that than sell you a report.',
  },
  {
    q: 'How is this different from a sponsor database?',
    a: 'Databases sell you the same list they sell everyone. This report is built for one newsletter: brands matched to your niche with dated evidence they already sponsor your peers, the person likely to own that budget with the source for each claim, and a written pitch per brand. Fixed price, no commission. Marketplaces charge 15 to 30 percent of every deal (Paved lists a 30 percent marketplace fee; Passionfroot up to 15 percent plus transaction fees, per their public pricing pages).',
  },
  {
    q: 'Does this only work for cybersecurity newsletters?',
    a: 'No. The sample is cybersecurity because it was our first vertical, but the method is niche-agnostic. What it does require is a vertical with enough comparable newsletters and podcasts that already carry sponsors, roughly ten or more. That is exactly what the fit check verifies before any work starts, and if your niche does not clear that bar, we tell you and refund in full.',
  },
  {
    q: 'Do you guarantee I will close a sponsor?',
    a: 'No, and you should distrust anyone who does. What we guarantee is the evidence: every brand in your report comes with a dated, linked sponsorship observation you can check yourself, and any email address we could not verify is marked as such.',
  },
  {
    q: 'Where does the data come from?',
    a: 'Public sources only: newsletter archives, podcast feeds, sponsor pages, press releases. Nothing scraped from behind a login, nobody contacted on your behalf, no guessed email addresses.',
  },
  {
    q: 'What do you need from me?',
    a: 'Five minutes: your newsletter URL, your niche in one sentence, subscriber count, open rate if you know it, and optionally the newsletters you consider comparable. The report is delivered within 5 business days as a PDF plus a CSV of contacts.',
  },
];
---

<Base
  title="Zeurion · Find the sponsors already buying newsletters like yours"
  description="A one-time prospecting report for niche B2B newsletter operators: 30 brands with dated proof they sponsor your peers, the right contact, and a ready-to-send pitch for each. €349, no commission."
>
  <header class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="mono eyebrow">Sponsor prospecting, done for you</p>
        <h1>30 brands already sponsoring newsletters like yours.</h1>
        <p class="sub">
          A one-time report for niche B2B newsletter operators (2,000 to 50,000 subscribers):
          who is actively buying sponsorships in your vertical, who owns that budget, and a
          ready-to-send pitch for each brand. No commission, no marketplace, no retainer.
        </p>
        {STRIPE_PAYMENT_LINK
          ? <a class="btn" href={STRIPE_PAYMENT_LINK}>Get your report · €349</a>
          : <a class="btn" href="mailto:contact@zeurion.ai?subject=Notify%20me%20when%20checkout%20opens">Opening soon at €349 · get notified</a>}
        <p class="cta-note mono">delivered in 5 business days · pdf + csv of contacts</p>
        <p class="guarantee">
          Fit check first: if your newsletter isn't right for the method, we say so and
          refund in full before any work starts. <a href="/terms">Terms</a>
        </p>
      </div>
      <div class="hero-proof">
        <p class="proof-caption mono">sample report · cybersecurity · ~15k subscribers · anonymized</p>
        <div class="inbox-window">
          <div class="inbox-bar">
            <span class="traffic" aria-hidden="true"><i></i><i></i><i></i></span>
            <span class="mono inbox-label">inbox · sponsor-opportunities</span>
            <span class="pill mono">30 unread</span>
          </div>
          <div class="inbox" role="list">
            {inboxRows.map((row, i) => (
              <div class="row" role="listitem" style={`--i: ${i}`}>
                <span class={`dot ${row.tier === 1 ? 'full' : ''}`} aria-hidden="true"></span>
                <span class="brand">{row.brand}</span>
                <span class="subject">{row.subject}</span>
                <span class="flag-slot">
                  {row.tier === 1 && (
                    <svg class="flag" viewBox="0 0 16 16" width="13" height="13" aria-label="Priority" role="img">
                      <path d="M3 1v14M3 2h9l-2.5 3L12 8H3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                </span>
                <span class="tag mono">{row.tag}</span>
                <span class="date mono">{row.date}</span>
              </div>
            ))}
            <div class="row more" role="listitem" style={`--i: ${inboxRows.length}`}>
              <span class="dot" aria-hidden="true" style="visibility:hidden"></span>
              <span class="subject mono">+ 24 more in the full report</span>
            </div>
          </div>
        </div>
        <p class="stats mono">
          103 dated observations · 14+ sources · every claim publicly sourced
        </p>
        <p class="proof-link"><a href="/sample">Read three full entries from the sample →</a></p>
      </div>
    </div>
  </header>

  <section class="proof reveal" aria-label="Free vertical pages">
    <div class="container">
      <div class="verticals">
        <p class="verticals-label">Browse observed sponsors in your vertical, free:</p>
        <p class="verticals-links">
          {verticals.map((v) => (
            <a class="chip" href={`/who-sponsors/${v.slug}`}>{v.name}<span class="mono chip-count"> {v.sponsors.length}</span></a>
          ))}
        </p>
      </div>
    </div>
  </section>

  <section class="offer reveal" aria-labelledby="offer-title">
    <div class="container">
      <h2 id="offer-title">What you get</h2>
      <ul class="offer-list">
        <li><strong>30 matched brands</strong>, each with dated, linked evidence that they already sponsor newsletters or podcasts your audience reads.</li>
        <li><strong>One contact per brand</strong>: name, role, the public source for both, and an honest email status (published, or to verify).</li>
        <li><strong>30 ready-to-send pitches</strong> anchored on each brand's observed sponsorship, plus two follow-up templates.</li>
        <li><strong>A pricing recommendation</strong> benchmarked against the only public rate card in your segment, so you don't price blind.</li>
        <li><strong>A mini media kit</strong>: the five numbers that sell your newsletter, and how to present them.</li>
      </ul>
      <h3>How it works</h3>
      <ol class="steps">
        <li>Order, then fill a five-minute intake form.</li>
        <li>We scan the public archives of the newsletters and podcasts comparable to yours.</li>
        <li>You receive the report within 5 business days: PDF plus a CSV of contacts.</li>
      </ol>
    </div>
  </section>

  <section class="pricing" id="buy" aria-labelledby="pricing-title">
    <div class="container">
      <h2 id="pricing-title">One report, one price</h2>
      <p class="price"><span class="mono">€349</span> one-time</p>
      <p class="section-note">
        One newsletter, one niche, one report. B2B service; VAT treatment depends on your
        country and is handled at checkout.
      </p>
      <p class="roi">
        The math: newsletters comparable to our sample sell primary placements at $1,950
        and up (CloudSecList's public rate card, sold out into 2026). One closed sponsor
        at that level covers this report several times over, and four booked slots a month
        is roughly $8,000 of inventory most niche newsletters leave unmonetized.
      </p>
      {STRIPE_PAYMENT_LINK
        ? <a class="btn" href={STRIPE_PAYMENT_LINK}>Get your report · €349</a>
        : <a class="btn" href="mailto:contact@zeurion.ai?subject=Notify%20me%20when%20checkout%20opens">Opening soon at €349 · get notified</a>}
      <p class="guarantee">
        Fit check first: if your newsletter isn't right for the method, we say so and
        refund in full before any work starts. <a href="/terms">Terms</a>
      </p>
    </div>
  </section>

  <section class="faq reveal" aria-labelledby="faq-title">
    <div class="container">
      <h2 id="faq-title">Questions, answered plainly</h2>
      {faq.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero { padding: 4rem 0 3rem; }
  .hero .container { max-width: 1120px; }
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: 3.5rem;
    align-items: center;
  }
  .hero h1 { font-size: clamp(2.2rem, 3.4vw, 2.75rem); text-wrap: balance; }
  .eyebrow { color: var(--accent); font-size: 0.875rem; margin-bottom: 1rem; }
  .sub { color: var(--ink-soft); margin: 1.25rem 0 2rem; font-size: 1.05rem; }
  .cta-note { color: var(--ink-soft); font-size: 0.8rem; margin-top: 0.8rem; }

  .proof-caption { color: var(--ink-soft); font-size: 0.78rem; margin-bottom: 0.6rem; }
  /* Variante hero : la date sort, l'objet respire (les dates restent sur /sample) */
  .hero-proof .row { grid-template-columns: 1rem 8.5rem 1fr auto auto; gap: 0.7rem; padding: 0.7rem 0.9rem; font-size: 0.95rem; }
  .hero-proof .row .date { display: none; }
  .hero-proof .row.more { grid-template-columns: 1rem 1fr; }
  .hero-proof .stats { margin: 0.9rem 0 0.4rem; font-size: 0.78rem; }
  .proof-link { font-size: 0.9rem; }
  .proof-link a { text-decoration: none; }
  .proof-link a:hover { text-decoration: underline; }

  /* Arrivée du courrier : stagger une fois au chargement, extension du
     scroll reveal v1.2. Sans JS ou en reduced-motion, tout est visible. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .hero-proof .row {
      opacity: 0;
      animation: row-in 250ms ease-out forwards;
      animation-delay: calc(150ms + var(--i, 0) * 70ms);
    }
  }
  @keyframes row-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: none; }
  }

  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-proof .row { grid-template-columns: 1rem 11rem 1fr auto auto auto; }
  }

  section { padding: 3.5rem 0 0; }
  .section-note { color: var(--ink-soft); margin: 0.75rem 0 1.5rem; max-width: 44rem; }

  .offer {
    background: var(--muted);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-top: 4rem;
    padding: 3.5rem 0;
  }
  .offer .tag, .offer .roi { background: var(--surface); }

  .inbox-window {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 12px 32px -18px rgba(22, 24, 29, 0.25);
  }
  .inbox-bar {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.6rem 1rem;
    background: var(--muted);
    border-bottom: 1px solid var(--line);
  }
  .traffic { display: flex; gap: 0.35rem; }
  .traffic i {
    width: 0.6rem; height: 0.6rem;
    border-radius: 50%;
    background: var(--line);
    display: block;
  }
  .inbox-label { font-size: 0.8rem; color: var(--ink-soft); }
  .pill {
    margin-left: auto;
    font-size: 0.72rem;
    background: var(--accent);
    color: var(--accent-ink);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
  }
  .inbox { background: var(--surface); }
  .row.more { grid-template-columns: 1rem 1fr; }
  .row.more .subject { color: var(--accent); font-size: 0.85rem; }
  .row {
    display: grid;
    grid-template-columns: 1rem 11rem 1fr auto auto auto;
    gap: 0.9rem;
    align-items: center;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--line);
    transition: background 180ms ease, transform 180ms ease;
  }
  .flag-slot { width: 13px; display: flex; justify-content: center; }
  .flag { color: var(--priority); flex-shrink: 0; }
  .row:last-child { border-bottom: none; }
  .row:hover { background: var(--muted); transform: translateX(2px); }
  .dot {
    width: 0.55rem; height: 0.55rem;
    border-radius: 50%;
    border: 1.5px solid var(--accent);
  }
  .dot.full { background: var(--accent); }
  .brand { font-weight: 600; }
  .subject { color: var(--ink-soft); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .tag { font-size: 0.72rem; background: var(--muted); border: 1px solid var(--line); border-radius: 4px; padding: 0.1rem 0.4rem; }
  .date { font-size: 0.8rem; color: var(--ink-soft); }
  .stats { color: var(--ink-soft); font-size: 0.85rem; margin: 1.25rem 0 0.5rem; }
  .proof .verticals { margin-top: 0; }
  .verticals { margin-top: 1.75rem; }
  .verticals-label { color: var(--ink-soft); font-size: 0.9rem; margin-bottom: 0.6rem; }
  .verticals-links { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.15rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    font-size: 0.9rem;
    color: var(--ink);
    text-decoration: none;
    text-transform: capitalize;
    transition: border-color 180ms ease;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip-count { font-size: 0.75rem; color: var(--ink-soft); }

  .offer-list { padding-left: 1.2rem; display: grid; gap: 0.75rem; margin: 1.25rem 0 2rem; }
  .steps { padding-left: 1.2rem; display: grid; gap: 0.5rem; margin-top: 1rem; color: var(--ink-soft); }

  .pricing {
    background: var(--ink);
    color: #f4f6f9;
    margin-top: 4.5rem;
    padding: 4rem 0;
  }
  .pricing h2 { color: #ffffff; }
  .pricing .section-note { color: #a6adbb; }
  .price { font-family: var(--font-display); font-size: 2.4rem; font-weight: 700; margin: 0.5rem 0; color: #ffffff; }
  .price .mono { font-family: var(--font-mono); }
  .roi {
    background: rgba(255, 255, 255, 0.06);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    padding: 0.85rem 1.1rem;
    color: #c9cfd9;
    max-width: 44rem;
    margin: 0 0 1.5rem;
  }
  .pricing .btn { background: var(--accent); }
  .pricing .btn:hover { background: #3563e9; }
  .pricing .guarantee { color: #a6adbb; }
  .pricing .guarantee a { color: #9db8ff; }
  .guarantee { color: var(--ink-soft); font-size: 0.9rem; margin-top: 0.9rem; max-width: 40rem; }

  .faq details {
    border-bottom: 1px solid var(--line);
    padding: 0.9rem 0;
  }
  .faq summary { font-weight: 600; cursor: pointer; }
  .faq details p { color: var(--ink-soft); margin-top: 0.6rem; max-width: 44rem; }

  @media (max-width: 720px) {
    .row, .hero-proof .row { grid-template-columns: 1rem 1fr auto; }
    .subject, .date, .flag-slot { display: none; }
    .row.more, .hero-proof .row.more { grid-template-columns: 1rem 1fr; }
    .row.more .subject { display: block; }
  }
</style>
